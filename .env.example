# =========================================================================
# Bakhus Assistant Production Environment Variables
# Copy this to .env on your server and modify for your environment.
# =========================================================================

# --- Public Endpoints ---
# Public URL of your API (must be accessible by n8n)
# Example: https://api.bahus.com or http://1.2.3.4
PUBLIC_API_URL=http://your-server-ip

# Public URL base for serving files (usually same as PUBLIC_API_URL)
PUBLIC_FILE_BASE_URL=http://your-server-ip/uploads

# --- n8n Integration ---
# Your n8n workflow webhook URL
N8N_IMPORT_WEBHOOK_URL=https://n8n.your-instance.com/webhook/your-uid

# --- Database ---
POSTGRES_USER=bakhus
POSTGRES_PASSWORD=bakhus_secure_password
POSTGRES_DB=bakhus
# Internal URL for the API to connect to the DB container
DATABASE_URL=postgresql://bakhus:bakhus_secure_password@postgres:5432/bakhus

# --- Application Admin ---
DEFAULT_MANAGER_EMAIL=manager@bakhus